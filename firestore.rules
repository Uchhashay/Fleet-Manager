rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'dhruvsingh349@gmail.com' ||
        (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role in ['admin', 'developer'])
      );
    }

    function isAccountant() {
      return isAuthenticated() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'accountant')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Helpers
    function isValidBooking(data) {
      return data.dutySlipNumber is string && 
             data.dutySlipNumber.size() > 0 &&
             data.dutySlipNumber.size() <= 64 &&
             data.hirerName is string &&
             data.hirerName.size() <= 200 &&
             data.finalAmount is number &&
             data.totalPaid is number &&
             data.balanceDue is number &&
             data.status is string;
    }

    function isValidHirer(data) {
      return data.hirerName is string &&
             data.hirerName.size() <= 200 &&
             data.contactNumber is string &&
             data.contactNumber.size() <= 20;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Validation Helpers for Bank
    function isValidBankAccount(data) {
      return data.account_name is string && data.account_name.size() <= 100 &&
             data.bank_name is string && data.bank_name.size() <= 100 &&
             data.account_type is string &&
             data.opening_balance is number &&
             data.current_balance is number;
    }

    function isValidBankTransaction(data) {
      return data.date is string &&
             data.type in ["in", "out"] &&
             data.amount is number && 
             data.description is string &&
             data.account_id is string &&
             data.payment_mode is string;
    }

    // Profiles (Users)
    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      match /{allSubcollections=**} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // Buses
    match /buses/{busId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
      
      match /{allSubcollections=**} {
        allow read: if isAuthenticated();
        allow write: if isAccountant();
      }
    }

    // Staff
    match /staff/{staffId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
      
      match /{allSubcollections=**} {
        allow read: if isAuthenticated();
        allow write: if isAccountant();
      }
      
      match /comments/{commentId} {
        allow read, create: if isAuthenticated();
        allow update, delete: if isAdmin();
      }
    }

    // Daily Records
    match /daily_records/{recordId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();

      match /{allSubcollections=**} {
        allow read: if isAuthenticated();
        allow write: if isAccountant();
      }
    }

    // Expenses
    match /bus_expenses/{expenseId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();

      match /{allSubcollections=**} {
        allow read: if isAuthenticated();
        allow write: if isAccountant();
      }
    }

    match /company_expenses/{expenseId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();

      match /{allSubcollections=**} {
        allow read: if isAuthenticated();
        allow write: if isAccountant();
      }
    }

    // Transactions
    match /cash_transactions/{transactionId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    match /accountant_transactions/{transactionId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    // Salary Records
    match /salary_records/{recordId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    // Counters
    match /counters/{counterId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    // Bank Accounts
    match /bank_accounts/{accountId} {
      allow read: if isAuthenticated(); // Relaxed for debugging fetch error
      allow write: if isAccountant();
    }

    match /bank_transactions/{txId} {
      allow read: if isAuthenticated(); // Relaxed for debugging fetch error
      allow write: if isAccountant();
    }

    // Organization
    match /organization/{orgId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Fee Collections
    match /fee_collections/{feeId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    // Students
    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
      
      match /{allSubcollections=**} {
        allow read: if isAuthenticated();
        allow write: if isAccountant();
      }
    }

    // Bills
    match /bills/{billId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    // B2B Clients
    match /b2bClients/{clientId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    // Schools
    match /schools/{schoolId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    // Activity Logs
    match /activity_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Hirers & Bookings (Travel Agency)
    match /hirers/{hirerId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant() && isValidId(hirerId) && isValidHirer(incoming());
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated();
      allow create: if isAccountant() && isValidId(bookingId) && isValidBooking(incoming());
      allow update: if isAccountant() && isValidId(bookingId) && isValidBooking(incoming());
      
      match /{allSubcollections=**} {
        allow read: if isAuthenticated();
        // Relaxed write for subcollections like activity/payments for now to ensure functionality
        allow write: if isAccountant();
      }
    }
    
    // Invoices & Receipts
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }
    
    match /receipts/{receiptId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    // Statement Uploads & Transactions
    match /statement_uploads/{uploadId} {
      allow read: if isAccountant();
      allow create, update: if isAccountant();
      allow delete: if isAdmin();
    }

    match /statement_transactions/{txId} {
      allow read: if isAccountant();
      allow create, update: if isAccountant();
      allow delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
