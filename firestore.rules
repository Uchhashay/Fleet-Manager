rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
             getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin') || hasRole('developer') || request.auth.token.email == "dhruvsingh349@gmail.com";
    }

    function isAccountant() {
      return hasRole('accountant') || isAdmin();
    }
    
    function isDeveloper() {
      return hasRole('developer') || request.auth.token.email == "dhruvsingh349@gmail.com";
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Profiles (Users)
    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      match /{allSubcollections=**} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // Buses
    match /buses/{busId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    // Staff
    match /staff/{staffId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
      
      match /comments/{commentId} {
        allow read, create: if isAuthenticated();
        allow update, delete: if isAdmin();
      }
    }

    // Daily Records
    match /daily_records/{recordId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant() || (isAuthenticated() && request.auth.token.email == "dhruvsingh349@gmail.com");

      match /editHistory/{historyId} {
        allow read: if isAuthenticated();
        allow create: if isAccountant() || (isAuthenticated() && request.auth.token.email == "dhruvsingh349@gmail.com");
        allow update, delete: if isAdmin();
      }
    }

    // Expenses
    match /bus_expenses/{expenseId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    match /company_expenses/{expenseId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    // Transactions
    match /cash_transactions/{transactionId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    // Salary Records
    match /salary_records/{recordId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    // Fee Collections
    match /fee_collections/{feeId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    // Students
    match /students/{studentId} {
      allow read: if isAccountant();
      allow write: if isAccountant();
      
      match /{allSubcollections=**} {
        allow read, write: if isAccountant();
      }
    }

    // Bills
    match /bills/{billId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    // B2B Clients
    match /b2bClients/{clientId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    // Schools
    match /schools/{schoolId} {
      allow read: if isAuthenticated();
      allow write: if isAccountant();
    }

    // Activity Logs
    match /activity_logs/{logId} {
      allow read: if isAccountant();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Hirers & Bookings (Travel Agency)
    match /hirers/{hirerId} {
      allow read: if isAccountant();
      allow write: if isAccountant();
    }

    match /bookings/{bookingId} {
      allow read: if isAccountant();
      allow write: if isAccountant();
      
      match /{allSubcollections=**} {
        allow read, write: if isAccountant();
      }
    }
    
    // Invoices & Receipts
    match /invoices/{invoiceId} {
      allow read, write: if isAccountant();
    }
    
    match /receipts/{receiptId} {
      allow read, write: if isAccountant();
    }
  }
}
